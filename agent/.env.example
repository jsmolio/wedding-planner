# OpenAI (required for LLM + embeddings)
OPENAI_API_KEY=sk-...

# Tavily (required for web search)
TAVILY_API_KEY=tvly-...

# LangSmith (recommended for tracing and evals)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=WeddingAgent

# Supabase (optional — tools use stubs when not configured)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
